# SolREM Backend Environment Variables

# Server
PORT=4000
NODE_ENV=development

# MongoDB - Local (comment out if using Atlas)
MONGODB_URI=mongodb://localhost:27017/solrem

# MongoDB Atlas (uncomment if you want to use cloud MongoDB)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/solrem?retryWrites=true&w=majority

# JWT
JWT_SECRET=solrem_jwt_secret_change_this_in_production

# Garmin API (currently using mock data)
GARMIN_CLIENT_ID=your_garmin_client_id
GARMIN_CLIENT_SECRET=your_garmin_client_secret
GARMIN_REDIRECT_URI=http://localhost:4000/api/garmin/callback

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=SoLrEmPrEdIcTiOnMaRkEtS1111111111111111111

# Optional: Oracle Wallet (for resolving markets on-chain)
# ORACLE_PRIVATE_KEY=your_base58_private_key_here
